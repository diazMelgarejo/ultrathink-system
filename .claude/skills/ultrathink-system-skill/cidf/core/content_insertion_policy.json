{
  "policy_id": "content_insertion_decision_framework",
  "framework_version": "1.2",
  "created": "2026-03-20",
  "purpose": "Minimize over-engineering and maximize completion rate for content insertion tasks across all AI agent frameworks.",
  "core_principle": "Use the simplest tool that works. Complexity is a cost, not a feature.",

  "inputs": {
    "task": {
      "task_type":                    "content_insertion | automation | data_processing",
      "is_one_time":                  true,
      "frequency_estimate":           1,
      "content_static":               true,
      "requires_transformation":      false,
      "requires_conditional_logic":   false,
      "requires_external_integration":false,
      "content_length_chars":         1200,
      "format_requirements":          "plain | rich_text | strict_layout",
      "signature":                    "<agent_fill: substring/hash to verify insertion>"
    },
    "environment": {
      "field_accessible":                 true,
      "editor_visible":                   true,
      "paste_supported":                  true,
      "upload_available":                 false,
      "max_safe_chars_form_input":        10000,
      "max_safe_chars_typing":            5000,
      "formatting_preserved_on_paste":    true
    }
  },

  "mode_selection": {
    "default_mode": "simplicity_first",
    "automation_justified_when_any": [
      "task.frequency_estimate >= 5",
      "task.requires_conditional_logic == true",
      "task.requires_transformation == true",
      "task.requires_external_integration == true"
    ],
    "scripting_blocked_when_any": [
      "task.is_one_time == true AND task.content_static == true",
      "ANY simpler method is eligible"
    ]
  },

  "tool_priority_order": [
    {
      "rank": 1,
      "tool": "direct_form_input",
      "complexity": 1,
      "eligible_when": [
        "environment.field_accessible == true",
        "task.content_length_chars <= environment.max_safe_chars_form_input"
      ],
      "skill_id": "skill_form_input"
    },
    {
      "rank": 2,
      "tool": "direct_typing",
      "complexity": 2,
      "eligible_when": [
        "environment.editor_visible == true",
        "task.content_length_chars <= environment.max_safe_chars_typing"
      ],
      "skill_id": "skill_direct_typing"
    },
    {
      "rank": 3,
      "tool": "clipboard_paste",
      "complexity": 2,
      "eligible_when": [
        "environment.paste_supported == true"
      ],
      "skill_id": "skill_clipboard_paste"
    },
    {
      "rank": 4,
      "tool": "file_upload",
      "complexity": 3,
      "eligible_when": [
        "environment.upload_available == true"
      ],
      "skill_id": "skill_file_upload"
    },
    {
      "rank": 5,
      "tool": "scripting",
      "complexity": 5,
      "eligible_when": [
        "task.frequency_estimate >= 5 OR task.requires_conditional_logic == true OR task.requires_transformation == true OR task.requires_external_integration == true"
      ],
      "block_when": [
        "task.is_one_time == true AND task.content_static == true",
        "ANY of ranks 1-4 is eligible"
      ],
      "skill_id": "skill_scripting"
    }
  ],

  "verification": {
    "must_verify": true,
    "visual_confirmation_insufficient": true,
    "steps": [
      "execute_chosen_method",
      "check_for_visual_update",
      "if_no_visual_refresh_once",
      "extract_text_programmatically",
      "check_signature_present_in_extracted_text",
      "if_present_mark_complete",
      "if_absent_log_failure_and_try_next_tool"
    ],
    "on_all_methods_fail": "notify_user_with_failure_log"
  },

  "anti_patterns": [
    {
      "id": "premature_scripting",
      "description": "Choosing scripting before trying any simpler method",
      "detection": "chosen_tool == scripting AND ANY of ranks 1-4 eligible",
      "consequence": "Wasted setup time, unnecessary complexity, higher failure rate",
      "fix": "Always iterate method list from rank 1"
    },
    {
      "id": "visual_assumption",
      "description": "Marking task complete because the UI appeared to update",
      "detection": "verification.must_verify == true AND programmatic_check_skipped",
      "consequence": "Silent failures, duplicate inserts, incorrect state",
      "fix": "Always call extract_text before marking complete"
    },
    {
      "id": "complexity_bias",
      "description": "Selecting a higher-complexity tool for perceived reliability",
      "detection": "chosen_complexity > minimum_eligible_complexity",
      "consequence": "Over-engineering, slower execution, harder debugging",
      "fix": "Trust the priority order; override only with explicit justification"
    },
    {
      "id": "failure_escalation",
      "description": "Jumping to scripting after a single failure of a simple method",
      "detection": "attempts_before_scripting < eligible_method_count - 1",
      "consequence": "Skips valid fallback methods, escalates unnecessarily",
      "fix": "Exhaust entire fallback_chain before escalating to scripting"
    }
  ],

  "test_vectors": [
    {
      "id": "TV-01",
      "description": "Static text, short, field accessible",
      "task": {"is_one_time":true,"frequency_estimate":1,"content_static":true,"requires_transformation":false,"requires_conditional_logic":false,"requires_external_integration":false,"content_length_chars":2000},
      "env":  {"field_accessible":true,"editor_visible":true,"paste_supported":true,"upload_available":false,"max_safe_chars_form_input":10000,"max_safe_chars_typing":5000},
      "expected_chosen_tool": "direct_form_input",
      "expected_automation_justified": false
    },
    {
      "id": "TV-02",
      "description": "Static text, 12k chars, field accessible but over limit",
      "task": {"is_one_time":true,"frequency_estimate":1,"content_static":true,"requires_transformation":false,"requires_conditional_logic":false,"requires_external_integration":false,"content_length_chars":12000},
      "env":  {"field_accessible":true,"editor_visible":false,"paste_supported":true,"upload_available":true,"max_safe_chars_form_input":10000,"max_safe_chars_typing":5000},
      "expected_chosen_tool": "clipboard_paste",
      "expected_automation_justified": false
    },
    {
      "id": "TV-03",
      "description": "Rich text, paste preserves formatting",
      "task": {"is_one_time":true,"frequency_estimate":1,"content_static":true,"requires_transformation":false,"requires_conditional_logic":false,"requires_external_integration":false,"content_length_chars":3000,"format_requirements":"rich_text"},
      "env":  {"field_accessible":false,"editor_visible":true,"paste_supported":true,"upload_available":false,"max_safe_chars_form_input":10000,"max_safe_chars_typing":5000,"formatting_preserved_on_paste":true},
      "expected_chosen_tool": "direct_typing",
      "expected_automation_justified": false
    },
    {
      "id": "TV-04",
      "description": "Editor not visible, upload available",
      "task": {"is_one_time":true,"frequency_estimate":1,"content_static":true,"requires_transformation":false,"requires_conditional_logic":false,"requires_external_integration":false,"content_length_chars":4000},
      "env":  {"field_accessible":false,"editor_visible":false,"paste_supported":false,"upload_available":true,"max_safe_chars_form_input":10000,"max_safe_chars_typing":5000},
      "expected_chosen_tool": "file_upload",
      "expected_automation_justified": false
    },
    {
      "id": "TV-05",
      "description": "Repeatable template, 20 uses, conditional logic",
      "task": {"is_one_time":false,"frequency_estimate":20,"content_static":false,"requires_transformation":false,"requires_conditional_logic":true,"requires_external_integration":false,"content_length_chars":500},
      "env":  {"field_accessible":true,"editor_visible":true,"paste_supported":true,"upload_available":true,"max_safe_chars_form_input":10000,"max_safe_chars_typing":5000},
      "expected_chosen_tool": "direct_form_input",
      "expected_automation_justified": true,
      "note": "Even when automation is justified, start at rank 1; scripting is fallback"
    },
    {
      "id": "TV-06",
      "description": "UI lag: no visual update — verify and do not duplicate",
      "task": {"is_one_time":true,"frequency_estimate":1,"content_static":true,"requires_transformation":false,"requires_conditional_logic":false,"requires_external_integration":false,"content_length_chars":500},
      "env":  {"field_accessible":true,"editor_visible":true,"paste_supported":true,"upload_available":false,"max_safe_chars_form_input":10000,"max_safe_chars_typing":5000},
      "expected_chosen_tool": "direct_form_input",
      "expected_automation_justified": false,
      "verification_behavior": "refresh_once_then_extract_text_before_marking_complete"
    }
  ],

  "outputs": {
    "decision": {
      "chosen_tool": "string",
      "fallback_chain": ["string"],
      "reason_codes": ["string"],
      "automation_justified": "boolean",
      "verification_required": true
    },
    "logging": {
      "fields": ["task_type","chosen_tool","attempts","failure_reasons","verification_result","elapsed_ms"]
    }
  }
}
