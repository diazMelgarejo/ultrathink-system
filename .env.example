# ultrathink-system v0.9.8.0 Configuration
# Copy to .env and fill in your actual values

# === API SERVER ===
API_HOST=0.0.0.0
API_PORT=8001

# === OLLAMA MODELS ===
DEFAULT_MODEL=qwen3.5:35b-a3b-q4_K_M
FAST_MODEL=qwen3:8b-instruct
CODE_MODEL=qwen3-coder:14b

# === OLLAMA ENDPOINTS (LAN setup) ===
# Mac mini / Mac Studio (primary reasoning host)
OLLAMA_MAC_ENDPOINT=http://192.168.1.101:11434
# Windows PC with RTX 3080 (fallback + code tasks)
OLLAMA_WINDOWS_ENDPOINT=http://192.168.1.100:11434
# Use localhost:11434 if running on same machine
# Ollama request timeout (sec) — sec: clamped to 1-600 in api_server.py
OLLAMA_TIMEOUT=120

# === SECURITY (v0.9.8.0) ===
# Restrict incoming hosts — set to comma-separated list in production
# Example: ALLOWED_HOSTS=localhost,192.168.1.101
ALLOWED_HOSTS=*
# * = allow all (dev default). Never use * in production.

# === PYTHON PATH ===
PYTHONPATH=./multi_agent/shared:./multi_agent

# === LOGGING ===
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# === SESSION-ONLY SECRETS (copy to .env.local - never commit) ===
# .env.local is gitignored; see .gitignore
# Add any API keys here if integrating cloud models (not recommended - ultrathink stays local)
