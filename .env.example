# orama-system v1.0 RC Configuration
# Copy to .env and fill in your actual values

# === API SERVER ===
API_HOST=0.0.0.0
API_PORT=8001

# === OLLAMA MODELS ===
DEFAULT_MODEL=Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-v2
FAST_MODEL=Qwen3.5-9B-MLX-4bit
CODE_MODEL=Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-v2

# === OLLAMA ENDPOINTS (LAN setup) ===
# Mac mini / Mac Studio (primary reasoning host)
OLLAMA_MAC_ENDPOINT=http://192.168.1.101:11434
# Windows PC with RTX 3080 (fallback + code tasks)
OLLAMA_WINDOWS_ENDPOINT=http://192.168.1.100:11434
# Use localhost:11434 if running on same machine
# Ollama request timeout (sec) — sec: clamped to 1-600 in api_server.py
OLLAMA_TIMEOUT=120

# === LM STUDIO — PRIMARY LOCAL BACKEND (v1.0 RC) ===
# Mac = Orchestrator + Validator (context=4096, safe for M2 16GB)
LM_STUDIO_MAC_ENDPOINT=http://localhost:1234
LMS_MAC_MODEL=Qwen3.5-9B-MLX-4bit
# macOS context conservative — same weights loadable in Ollama if needed
LMS_MAC_CONTEXT=8192

# Windows = UltraThink Agent(s) — comma-separated, 1-4 machines
# IP address of the Windows LM Studio host on your LAN.
# Example: WIN_LM_STUDIO_HOST=192.168.1.50
# Do NOT commit a real IP here.
WIN_LM_STUDIO_HOST=
LM_STUDIO_WIN_ENDPOINTS=http://192.168.254.108:1234,http://192.168.1.100:1234
# Add more: http://192.168.1.101:1234,http://192.168.1.102:1234 (max 4)
LMS_WIN_MAX_PARALLEL=4
LMS_WIN_MODEL=Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-v2
# Win GPU settings (set in LM Studio UI): GPU Offload=40, Context=16384
# GGUF file also compatible with Ollama, koboldcpp, llama.cpp

LM_STUDIO_API_TOKEN=lmstudio
LM_STUDIO_TIMEOUT=120

# === PORTAL ===
PORTAL_PORT=8002
PORTAL_HOST=0.0.0.0

# === CLOUD VERIFICATION (optional — budget-gated via PT /orchestrate) ===
ORCHESTRATOR_ENDPOINT=http://localhost:8000

# === SECURITY (v1.0 RC) ===
# Restrict incoming hosts — set to comma-separated list in production
# Example: ALLOWED_HOSTS=localhost,192.168.1.101
ALLOWED_HOSTS=*
# * = allow all (dev default). Never use * in production.

# === PERPETUA-TOOLS CROSS-REPO PATH (required for hardware policy enforcement) ===
# orama imports utils.hardware_policy from Perpetua-Tools (PT is authoritative).
# Set this to the absolute path of your PT checkout.
# Default assumes repos are siblings: ../perplexity-api/Perpetua-Tools
# If PT is unreachable, orama falls back to config/hardware_policy_cache.yml (degraded).
# REQUIRED: set this in .env with the full expanded path for your machine.
# PERPETUA_TOOLS_ROOT=/absolute/path/to/perplexity-api/Perpetua-Tools

# === PYTHON PATH ===
PYTHONPATH=PYTHONPATH:./bin/orama-system:./bin/shared:./bin

# === LOGGING ===
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# === SESSION-ONLY SECRETS (copy to .env.local - never commit) ===
# .env.local is gitignored; see .gitignore
# Add any API keys here if integrating cloud models (not recommended - ultrathink stays local)
# xAI / Grok (finance/M&A/factcheck fallback only; optional)
# Get key at: https://console.x.ai/
XAI_API_KEY=
SETUP_PASSWORD=change-me-before-network-use
