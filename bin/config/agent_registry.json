{
  "version": "0.9.9.8",
  "network_name": "ultrathink-agent-network",
  "description": "Unified ultrathink agent network — 7 ultrathink stage agents + 4 OpenClaw SOUL agents",
  "openclaw_agents": {
    "mac-researcher":  { "soul": "bin/agents/mac-researcher/SOUL.md",  "provider": "lmstudio-mac",  "model": "Qwen3.5-9B-MLX-4bit", "affinity": "mac", "gateway": "http://127.0.0.1:18789" },
    "win-researcher":  { "soul": "bin/agents/win-researcher/SOUL.md",  "provider": "lmstudio-win",  "model": "Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-v2", "affinity": "win", "gateway": "http://127.0.0.1:18789" },
    "coder":           { "soul": "bin/agents/coder/SOUL.md",            "provider": "lmstudio-win",  "model": "Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-v2", "affinity": "win", "gateway": "http://127.0.0.1:18789" },
    "autoresearcher":  { "soul": "bin/agents/autoresearcher/SOUL.md",   "provider": "lmstudio-win",  "model": "Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-v2", "affinity": "win", "gateway": "http://127.0.0.1:18789" }
  },
  "agents": [
    {
      "id": "orchestrator",
      "type": "coordinator",
      "affinity": "mac",
      "skill_path": "agents/orchestrator/ultrathink-orchestrator.md",
      "logic_path": "agents/orchestrator/orchestrator_logic.py",
      "max_instances": 1,
      "tools": ["state_manager", "message_bus", "all_agent_delegators"]
    },
    {
      "id": "context-agent",
      "type": "specialist",
      "affinity": "mac",
      "stage": 1,
      "skill_path": "agents/context/context-immersion-agent.md",
      "logic_path": "agents/context/context_tools.py",
      "max_instances": 3,
      "tools": ["git_history", "documentation_reader", "code_analyzer", "lessons_db"]
    },
    {
      "id": "architect-agent",
      "type": "specialist",
      "affinity": "mac",
      "stage": 2,
      "skill_path": "agents/architect/visionary-architect-agent.md",
      "logic_path": "agents/architect/architecture_tools.py",
      "max_instances": 2,
      "tools": ["module_decomposer", "interface_designer", "diagram_generator"]
    },
    {
      "id": "refiner-agent",
      "type": "specialist",
      "affinity": "mac",
      "stage": 3,
      "skill_path": "agents/refiner/ruthless-refiner-agent.md",
      "logic_path": "agents/refiner/refinement_tools.py",
      "max_instances": 2,
      "tools": ["complexity_analyzer", "redundancy_detector", "rubric_evaluator"]
    },
    {
      "id": "executor-agent",
      "type": "worker",
      "affinity": "win",
      "stage": 4,
      "skill_path": "agents/executor/masterful-executor-agent.md",
      "logic_path": "agents/executor/execution_tools.py",
      "max_instances": 5,
      "tools": ["code_generator", "test_generator", "linter", "performance_profiler"]
    },
    {
      "id": "verifier-agent",
      "type": "validator",
      "affinity": "mac",
      "stage": 4.5,
      "skill_path": "agents/verifier/verification-agent.md",
      "logic_path": "agents/verifier/verification_tools.py",
      "max_instances": 2,
      "tools": ["test_runner", "diff_analyzer", "scenario_generator"]
    },
    {
      "id": "crystallizer-agent",
      "type": "documenter",
      "affinity": "mac",
      "stage": 5,
      "skill_path": "agents/crystallizer/vision-crystallizer-agent.md",
      "logic_path": "agents/crystallizer/documentation_tools.py",
      "max_instances": 1,
      "tools": ["diagram_generator", "lessons_db", "documentation_writer"]
    }
  ],
  "autoresearch_agents": {
    "_comment": "Pre-defined agent types for autoresearch swarm (task_type=autoresearch). Spawned by Perplexity-Tools AgentTracker; registered here for ultrathink Mode 3 awareness only.",
    "autoresearch-coder": {
      "id": "autoresearch-coder",
      "type": "worker",
      "affinity": "win-rtx3080",
      "model_role": "autoresearch-coder",
      "responsibilities": [
        "Call CIDF decide() before editing train.py (rank 2: direct_typing on local file)",
        "Deploy train.py via autoresearch_bridge.deploy_train_py() (scp)",
        "Dispatch run via autoresearch_bridge.run_experiment_on_gpu()",
        "Flip swarm_state.md GPU: IDLE→BUSY before run, BUSY→IDLE after fetch_run_log()"
      ],
      "max_instances": 1,
      "idempotency": "AgentTracker.find_existing('autoresearch-coder', task_hash)"
    },
    "autoresearch-evaluator": {
      "id": "autoresearch-evaluator",
      "type": "validator",
      "affinity": "mac",
      "model_role": "autoresearch-critic",
      "responsibilities": [
        "Read log.txt via autoresearch_bridge.fetch_run_log()",
        "Parse val_bpb programmatically — LINT-002 verification_required=True (no visual confirmation)",
        "Write findings to swarm_state.md evaluator_findings section"
      ],
      "max_instances": 1,
      "idempotency": "AgentTracker.find_existing('autoresearch-evaluator', task_hash)"
    },
    "autoresearch-orchestrator": {
      "id": "autoresearch-orchestrator",
      "type": "coordinator",
      "affinity": "mac",
      "model_role": "strategy",
      "responsibilities": [
        "Read swarm_state.md + git log to understand current experiment state",
        "Propose next hypothesis; write orchestrator_directive to swarm_state.md",
        "Coordinate coder + evaluator lifecycle via Perplexity-Tools AgentTracker"
      ],
      "max_instances": 1,
      "idempotency": "AgentTracker.find_existing('autoresearch-orchestrator', task_hash)"
    }
  },
  "routing": {
    "task_received":          "orchestrator",
    "context_needed":         "context-agent",
    "design_needed":          "architect-agent",
    "refinement_needed":      "refiner-agent",
    "implementation_needed":  "executor-agent",
    "verification_needed":    "verifier-agent",
    "documentation_needed":   "crystallizer-agent",
    "autoresearch_received":  "autoresearch-orchestrator",
    "autoresearch_coding":    "autoresearch-coder",
    "autoresearch_eval":      "autoresearch-evaluator"
  },
  "quality_gates": {
    "context_confidence_min": 0.7,
    "elegance_threshold":     0.8,
    "max_refinement_loops":   3,
    "max_executor_agents":    5,
    "max_nesting_depth":      3
  }
}
