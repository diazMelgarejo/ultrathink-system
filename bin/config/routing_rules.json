{
  "version": "2.0.0",
  "description": "Routing rules for ultrathink multi-agent message dispatch",
  "rules": [
    {
      "id": "route-cidf-insertion",
      "description": "Content insertion tasks must go to CIDF-aware executor only",
      "condition": {
        "task_type": "content_insertion"
      },
      "destination": "executor-agent",
      "cidf_required": true,
      "priority": 10
    },
    {
      "id": "route-cidf-lint-fail",
      "description": "CIDF lint failure routes back to architect for method correction",
      "condition": {
        "cidf_lint_failed": true
      },
      "destination": "architect-agent",
      "priority": 11
    },
    {
      "id": "route-task-start",
      "description": "New tasks always go to orchestrator",
      "condition": {
        "message_type": "new_task"
      },
      "destination": "orchestrator",
      "priority": 10
    },
    {
      "id": "route-context",
      "description": "Context requests go to context-agent",
      "condition": {
        "current_stage": "context_immersion"
      },
      "destination": "context-agent",
      "priority": 9
    },
    {
      "id": "route-architecture",
      "description": "Architecture requests go to architect-agent",
      "condition": {
        "current_stage": "architecture"
      },
      "destination": "architect-agent",
      "priority": 9
    },
    {
      "id": "route-refinement",
      "description": "Low elegance score triggers refiner",
      "condition": {
        "elegance_score_lt": 0.8,
        "iteration_count_lt": 3
      },
      "destination": "refiner-agent",
      "priority": 8
    },
    {
      "id": "route-execution",
      "description": "Ready designs go to executor(s)",
      "condition": {
        "current_stage": "execution"
      },
      "destination": "executor-agent",
      "allow_parallel": true,
      "max_instances": 5,
      "priority": 7
    },
    {
      "id": "route-verification",
      "description": "Completed implementations go to verifier",
      "condition": {
        "current_stage": "verification"
      },
      "destination": "verifier-agent",
      "priority": 9
    },
    {
      "id": "route-crystallization",
      "description": "Verified results go to crystallizer",
      "condition": {
        "verification_verdict": "PASS"
      },
      "destination": "crystallizer-agent",
      "priority": 7
    },
    {
      "id": "route-re-execute",
      "description": "Failed verification triggers re-execution",
      "condition": {
        "verification_verdict": "FAIL",
        "retry_count_lt": 2
      },
      "destination": "executor-agent",
      "priority": 8
    }
  ],
  "dead_letter": {
    "destination": "orchestrator",
    "description": "Unrouted messages return to orchestrator for handling"
  },
  "cidf_policy": {
    "version": "1.2",
    "policy_file": "bin/orama-system/cidf/core/content_insertion_policy.json",
    "linter": "bin/orama-system/cidf/linter/policy_linter.py",
    "enforcement": "strict",
    "note": "All content insertion routed through CIDF-aware executors only"
  }
}