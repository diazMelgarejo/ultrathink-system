{
  "name": "orama-operator-console",
  "private": true,
  "version": "0.9.9.8",
  "type": "module",
  "description": "Dense dark operator console for orama-system v1.0.0.0 RC-1. Pairs with portal_server.py backend.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
